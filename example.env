# MongoDB connection URI (replace with your own)
MONGO_URI=mongodb+srv://<username>:<password>@...

# Name of the database to use
MONGO_DB_NAME=img_uploadbot

# ID list of all admins who can broadcast (without space after comma)
ADMIN_IDS=7855536617,5190902724

# Telegram API credentials (get from https://my.telegram.org)
API_ID=12345...
API_HASH=12345abcdefgh....

# Bot token from @BotFather
BOT_TOKEN=12345678:abcdefghij...

# Webhook URL (https://your-vercel-app-url.vercel.app/api/webhook)
WEBHOOK_URL=https://your-domain.com

# Enable or disable force subscription (true/false)
FORCE_SUB=true

# Channel username for force subscription (include @, bot must be admin)
FORCE_SUB_CHANNEL=@XylonBots